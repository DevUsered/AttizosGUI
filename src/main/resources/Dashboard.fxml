<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" styleClass="root-dashboard" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox prefHeight="660.0" prefWidth="1060.0" styleClass="glass-container" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">

            <VBox prefWidth="260.0" styleClass="sidebar">

                <padding>
                    <Insets bottom="20" left="20" right="20" top="25" />
                </padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="logo-icon" text="" />
                    <Label styleClass="logo-text" text="Music" />
                </HBox>
                <AnchorPane prefHeight="22.0" prefWidth="220.0" styleClass="search-box">
                    <VBox.margin>
                        <Insets bottom="10.0" top="20.0" />
                    </VBox.margin>
                    <children>
                        <Label layoutX="15" layoutY="12" styleClass="search-icon" text="🔍" />

                        <Label layoutX="45" layoutY="12" styleClass="search-text" text="Search..." />
                    </children>
                </AnchorPane>
                <Label styleClass="section-title" text="Menu" />

                <VBox spacing="8">

                    <Button styleClass="menu-button-active" text="🏠  Home" />

                    <Button styleClass="menu-button" text="🧭  Discover" />

                    <Button styleClass="menu-button" text="📚  Browse" />

                    <Button styleClass="menu-button" text="🎙  Podcasts" />

                    <Button styleClass="menu-button" text="📻  Radio" />

                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <Separator styleClass="separator" />

                <Label styleClass="section-title" text="Library" />

                <VBox spacing="8">

                    <Button styleClass="menu-button" text="📀  Albums" />

                    <Button styleClass="menu-button" text="🎵  Songs" />

                    <Button styleClass="menu-button" text="👤  Artists" />

                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <Separator styleClass="separator" />

                <!-- PERFIL -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="profile-box">

                    <Label styleClass="profile-avatar" text="👨" />

                    <VBox>
                        <Label styleClass="profile-name" text="Edgar" />

                        <Label styleClass="profile-role" text="Premium member" />
                    </VBox>

                </HBox>

            </VBox>
            <AnchorPane styleClass="content-area" HBox.hgrow="ALWAYS" />

        </HBox>

    </children>
   <stylesheets>
      <URL value="@css/style.css" />
      <URL value="@css/style.css" />
   </stylesheets>

</AnchorPane>
