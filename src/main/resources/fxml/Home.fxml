<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="950.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Attizos.Frontend.HomeController">
    <children>
        <ImageView fitHeight="149.0" fitWidth="143.0" layoutX="30.0" layoutY="9.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../images/Logo_attizos.png" />
            </image>
        </ImageView>
        <Label layoutX="380.0" layoutY="25.0" text="MENÚ" textFill="WHITE">
            <font>
                <Font name="System Bold" size="40.0" />
            </font>
        </Label>
        <Button layoutX="800.0" layoutY="35.0" mnemonicParsing="false" onAction="#login" prefHeight="35.0" prefWidth="110.0" styleClass="btn-top" text="Ingresar" />
        <VBox alignment="CENTER" layoutX="40.0" layoutY="110.0" prefWidth="870.0">
            <children>
                <ComboBox fx:id="comboBoxCategories" prefHeight="35.0" prefWidth="280.0" promptText="Seleccionar categoría..." styleClass="combo-personalizado" />
            </children>
        </VBox>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" layoutX="40.0" layoutY="170.0" prefHeight="500.0" prefWidth="870.0" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <FlowPane fx:id="containerProducts" alignment="TOP_CENTER" hgap="30.0" prefWrapLength="840.0" vgap="30.0" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets bottom="30.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>