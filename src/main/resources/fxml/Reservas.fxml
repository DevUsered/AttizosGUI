<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #120524;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Attizos.Frontend.ReservasController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label text="📅 GESTIÓN INTEGRAL DE RESERVAS" textFill="WHITE">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                        <AnchorPane HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>

                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <TableView fx:id="tablaReservas" style="-fx-base: #1a0a2a; -fx-control-inner-background: #1a0a2a; -fx-background-color: #1a0a2a; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                                        <TableColumn fx:id="colCliente" prefWidth="130.0" text="CLIENTE" />
                                        <TableColumn fx:id="colTelefono" prefWidth="90.0" text="TELÉFONO" />
                                        <TableColumn fx:id="colPersonas" prefWidth="50.0" text="PAX" />
                                        <TableColumn fx:id="colFechaHora" prefWidth="130.0" text="FECHA/HORA" />
                                        <TableColumn fx:id="colEstado" prefWidth="100.0" text="ESTADO" />
                                        <TableColumn fx:id="colObservaciones" prefWidth="150.0" text="OBSERVACIONES" />
                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                </TableView>
                                <HBox spacing="15.0">
                                    <children>
                                        <Button maxWidth="Infinity" onAction="#cancelarReservaSeleccionada" prefHeight="40.0" style="-fx-background-color: rgba(255, 76, 76, 0.1); -fx-border-color: #ff4c4c; -fx-border-radius: 8; -fx-border-width: 2; -fx-text-fill: #ff4c4c; -fx-font-weight: bold;" text="🚫 Cancelar" HBox.hgrow="ALWAYS" />
                                        <Button maxWidth="Infinity" onAction="#finalizarReservaSeleccionada" prefHeight="40.0" style="-fx-background-color: rgba(0, 210, 255, 0.1); -fx-border-color: #00d2ff; -fx-border-radius: 8; -fx-border-width: 2; -fx-text-fill: #00d2ff; -fx-font-weight: bold;" text="✅ Atender" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox minWidth="350.0" prefWidth="350.0" spacing="10.0" style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-radius: 15;">
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Nueva Reserva" textFill="WHITE" />

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Cliente:" textFill="#b39ddb" />
                                        <TextField fx:id="txtCliente" style="-fx-background-color: rgba(0,0,0,0.3); -fx-text-fill: white;" />

                                        <Label text="Teléfono:" textFill="#b39ddb" />
                                        <TextField fx:id="txtTelefono" style="-fx-background-color: rgba(0,0,0,0.3); -fx-text-fill: white;" />

                                        <HBox spacing="10.0">
                                            <children>
                                                <VBox HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Personas:" textFill="#b39ddb" />
                                                        <TextField fx:id="txtPersonas" style="-fx-background-color: rgba(0,0,0,0.3); -fx-text-fill: white;" />
                                                    </children>
                                                </VBox>
                                                <VBox HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Mesa Nro:" textFill="#b39ddb" />
                                          <Label text="NO DEFINIDA" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <Label text="Fecha:" textFill="#b39ddb" />
                                        <DatePicker fx:id="dpFecha" prefWidth="Infinity" style="-fx-base: #1a0a2a;" />

                                        <Label text="Hora:" textFill="#b39ddb" />
                                        <ComboBox fx:id="cmbHora" prefWidth="Infinity" style="-fx-base: #1a0a2a;" />

                                        <Label text="Observaciones:" textFill="#b39ddb" />
                                        <TextArea fx:id="txtObservaciones" prefHeight="80.0" style="-fx-control-inner-background: rgba(0,0,0,0.3); -fx-text-fill: white;" wrapText="true" />
                                    </children>
                                </VBox>

                                <Button onAction="#guardarReserva" prefHeight="45.0" prefWidth="Infinity" style="-fx-background-color: linear-gradient(to right, #00ff88, #00cc6a); -fx-text-fill: #120524; -fx-font-weight: bold;" text="💾 CONFIRMAR RESERVA" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
