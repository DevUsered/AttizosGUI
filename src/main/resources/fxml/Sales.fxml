<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane style="-fx-background-color: transparent;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Attizos.Frontend.VentasController">
    <children>
        <Label text="Punto de Venta" textFill="WHITE" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <TextField prefHeight="35.0" prefWidth="237.0" promptText="🔍 Buscar producto..." style="-fx-background-color: rgba(15, 5, 30, 0.6); -fx-text-fill: white; -fx-prompt-text-fill: #a0a0a0; -fx-background-radius: 10; -fx-padding: 8 15; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 10;" AnchorPane.leftAnchor="268.0" AnchorPane.topAnchor="22.0" />

        <Label styleClass="section-title" text="Categorías" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="80.0" />

        <ScrollPane fx:id="sPCategoria" fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" prefHeight="60.0" style="-fx-background: transparent; -fx-background-color: transparent;" vbarPolicy="NEVER" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="340.0" AnchorPane.topAnchor="110.0">
            <content>
                <HBox fx:id="hBCategoria" alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: transparent;" />
            </content>
        </ScrollPane>

        <Label styleClass="section-title" text="Menú de Productos" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="185.0" />

        <ScrollPane fx:id="sPProductos" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="340.0" AnchorPane.topAnchor="215.0">
            <content>
                <FlowPane fx:id="flPProductos" hgap="15.0" style="-fx-background-color: transparent;" vgap="15.0" />
            </content>
        </ScrollPane>
        <AnchorPane fx:id="aPCarrito" prefWidth="300.0" styleClass="glass-container" AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label text="Orden Actual" textFill="WHITE" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <TextField fx:id="tfNombreCli" prefHeight="35.0" promptText="Nombre del cliente..." style="-fx-background-color: rgba(15, 5, 30, 0.6); -fx-text-fill: white; -fx-prompt-text-fill: #a0a0a0; -fx-background-radius: 10; -fx-padding: 8 15; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 10;" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="55.0" />

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" AnchorPane.bottomAnchor="160.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="100.0">
                    <content>
                        <VBox fx:id="vBoxCarrito" spacing="10.0" style="-fx-background-color: transparent;" />
                    </content>
                </ScrollPane>

                <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0">
                    <children>
                        <AnchorPane prefHeight="1.0" style="-fx-background-color: rgba(255,255,255,0.2);" />

                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="Total a pagar:" textFill="#b39ddb">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label styleClass="product-price" text="Bs. " />
                                <Label fx:id="lblTotal" styleClass="product-price" text="0.00" />
                            </children>
                        </HBox>

                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <Button fx:id="btnReducir" maxWidth="Infinity" mnemonicParsing="false" onAction="#reducirProducto" prefHeight="35.0" styleClass="btn-top" text="➖ Reducir" HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnQuitar" maxWidth="Infinity" mnemonicParsing="false" onAction="#quitarProducto" prefHeight="35.0" style="-fx-background-color: transparent; -fx-border-color: #ff4c4c; -fx-border-radius: 20; -fx-border-width: 2; -fx-text-fill: #ff4c4c; -fx-font-weight: bold; -fx-cursor: hand;" text="🗑 Quitar" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>

                        <Button fx:id="btnFinalizar" maxWidth="Infinity" mnemonicParsing="false" onAction="#finalizarVenta" prefHeight="40.0" style="-fx-background-color: linear-gradient(to right, #00ff88, #00cc6a); -fx-text-fill: #120524; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 12; -fx-cursor: hand;" text="✅ Confirmar Venta" />
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
