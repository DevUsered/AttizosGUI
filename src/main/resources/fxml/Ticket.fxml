<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox maxWidth="-Infinity" minWidth="-Infinity" prefWidth="300.0" style="-fx-background-color: white; -fx-padding: 10; -fx-font-family: 'Monospaced'; -fx-font-size: 12px;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Attizos.Frontend.TicketController">
    <children>

        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/Logo_attizos_BN.png" />
                    </image>
                </ImageView>
                <VBox alignment="CENTER_LEFT">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: black;" text="PIZZERÍA ATTIZOS" />
                        <Label fx:id="lblNumFacturaCaja" style="-fx-text-fill: black;" text="Ticket Nro: 000" />
                    </children>
                </VBox>
            </children>
            <VBox.margin>
                <Insets bottom="10.0" top="5.0" />
            </VBox.margin>
        </HBox>

        <VBox spacing="2.0">
            <children>
                <Label fx:id="lblFechaCaja" style="-fx-text-fill: black;" text="Fecha: 00/00/0000 HH:mm" />
                <Label fx:id="lblCajero" style="-fx-text-fill: black;" text="Caja/Usuario: Edgar Perez" />
                <Label fx:id="lblClienteCaja" style="-fx-text-fill: black;" text="Cliente: Consumidor Final" />
            </children>
        </VBox>

        <Region style="-fx-border-color: black; -fx-border-style: dashed; -fx-border-width: 1 0 0 0;">
            <VBox.margin> <Insets bottom="5.0" top="8.0" /> </VBox.margin>
        </Region>

        <HBox>
            <children>
                <Label prefWidth="35.0" style="-fx-font-weight: bold; -fx-text-fill: black;" text="CANT" />
                <Label prefWidth="150.0" style="-fx-font-weight: bold; -fx-text-fill: black;" text="PRODUCTO" />
                <Label alignment="CENTER_RIGHT" prefWidth="95.0" style="-fx-font-weight: bold; -fx-text-fill: black;" text="SUBTOTAL" />
            </children>
        </HBox>

        <Region style="-fx-border-color: black; -fx-border-style: dashed; -fx-border-width: 1 0 0 0;">
            <VBox.margin> <Insets bottom="5.0" top="5.0" /> </VBox.margin>
        </Region>

        <VBox fx:id="vboxProductosCaja" spacing="3.0" />

        <Region style="-fx-border-color: black; -fx-border-style: dashed; -fx-border-width: 1 0 0 0;">
            <VBox.margin> <Insets bottom="5.0" top="5.0" /> </VBox.margin>
        </Region>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: black;" text="TOTAL A PAGAR:" />
                <Label fx:id="lblTotalCaja" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: black;" text="Bs. 0.00" />
            </children>
        </HBox>

        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #666666;" text="✂ - - - - - - - - - - - - - - - - - - ">
            <VBox.margin>
                <Insets bottom="15.0" top="15.0" />
            </VBox.margin>
        </Label>

        <VBox alignment="CENTER" spacing="5.0">
            <children>
                <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/Logo_attizos_BN.png" />
                    </image>
                </ImageView>
                <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: black;" text="PIZZERÍA ATTIZOS" />
                <Label style="-fx-text-fill: black;" text="SU TURNO:" />
                <Label fx:id="lblTurnoCliente" style="-fx-font-weight: bold; -fx-font-size: 36px; -fx-text-fill: black;" text="#000" />
            </children>
            <VBox.margin> <Insets bottom="10.0" /> </VBox.margin>
        </VBox>

        <VBox spacing="2.0">
            <children>
                <Label fx:id="lblFechaCliente" style="-fx-text-fill: black;" text="Fecha: 00/00/0000 HH:mm" />
                <Label fx:id="lblClienteCliente" style="-fx-text-fill: black;" text="Cliente: Consumidor Final" />
            </children>
        </VBox>

        <Region style="-fx-border-color: black; -fx-border-style: dashed; -fx-border-width: 1 0 0 0;">
            <VBox.margin> <Insets bottom="5.0" top="5.0" /> </VBox.margin>
        </Region>

        <VBox fx:id="vboxProductosCliente" spacing="3.0" />

        <Region style="-fx-border-color: black; -fx-border-style: dashed; -fx-border-width: 1 0 0 0;">
            <VBox.margin> <Insets bottom="5.0" top="5.0" /> </VBox.margin>
        </Region>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: black;" text="TOTAL PAGADO:" />
                <Label fx:id="lblTotalCliente" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: black;" text="Bs. 0.00" />
            </children>
        </HBox>

        <VBox alignment="CENTER" spacing="5.0">
            <VBox.margin>
                <Insets top="15.0" />
            </VBox.margin>
            <children>
                <Label style="-fx-text-fill: black;" text="¡Gracias por su preferencia!" textAlignment="CENTER" />
            </children>
        </VBox>

    </children>
</VBox>