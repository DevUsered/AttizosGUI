<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER_LEFT" prefHeight="350.0" prefWidth="380.0" spacing="25.0" style="-fx-background-color: rgba(38, 15, 65, 0.95); -fx-padding: 40; -fx-background-radius: 20; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-width: 1; -fx-border-radius: 20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Attizos.Frontend.LoginController">
    <children>

        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <StackPane prefHeight="75.0" prefWidth="75.0" styleClass="logo-circle">
                    <children>
                        <ImageView fx:id="logoEmpresa" fitHeight="55.0" fitWidth="55.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/Logo_attizos.png" />
                            </image>
                        </ImageView>
                    </children>
                </StackPane>
                <Label text="Login" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
            </children>
        </HBox>
        <VBox spacing="15.0">
            <children>
                <TextField fx:id="txtUsuario" onAction="#enfocarPassword" promptText="Usuario" style="-fx-background-color: rgba(15, 5, 30, 0.6); -fx-text-fill: white; -fx-prompt-text-fill: #a0a0a0; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 10;" />
                <PasswordField fx:id="txtPassword" onAction="#iniciarSesion" promptText="Contraseña" style="-fx-background-color: rgba(15, 5, 30, 0.6); -fx-text-fill: white; -fx-prompt-text-fill: #a0a0a0; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 10;" />
            </children>
        </VBox>

        <Label fx:id="lblMensaje" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #ff4c4c; -fx-font-size: 12px; -fx-font-weight: bold;" />

        <Button fx:id="btnLogin" maxWidth="Infinity" mnemonicParsing="false" onAction="#iniciarSesion" style="-fx-background-color: linear-gradient(to right, #7e57c2, #5e35b1); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 10; -fx-padding: 12; -fx-cursor: hand;" text="Iniciar Sesión" />
    </children>
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
</VBox>
