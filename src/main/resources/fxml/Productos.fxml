<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="1150.0" style="-fx-background-color: #120524;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Attizos.Frontend.GestionMenuController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label text="🍕 GESTIÓN DE MENÚ Y RECETAS" textFill="WHITE">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                        <AnchorPane HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>

                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>

                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 8; -fx-padding: 10;">
                                    <children>
                                        <Label text="🔍 Buscar:" textFill="#00d2ff">
                                            <font><Font name="System Bold" size="14.0" /></font>
                                        </Label>
                                        <TextField fx:id="txtBuscador" promptText="Escriba el nombre, categoría o ID del producto..." style="-fx-background-color: rgba(0,0,0,0.4); -fx-text-fill: white; -fx-pref-width: 350;" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <Label text="📋 Productos Registrados en el Menú:" textFill="#b39ddb">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>

                                <TableView fx:id="tablaMenu" style="-fx-base: #1a0a2a; -fx-control-inner-background: #1a0a2a; -fx-background-color: #1a0a2a; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                        <TableColumn fx:id="colNombre" prefWidth="180.0" text="PRODUCTO" />
                                        <TableColumn fx:id="colCategoria" prefWidth="100.0" text="CATEGORÍA" />
                                        <TableColumn fx:id="colPrecio" prefWidth="80.0" text="PRECIO Bs" />
                                        <TableColumn fx:id="colStock" prefWidth="80.0" text="STOCK" />
                                        <TableColumn fx:id="colTipo" prefWidth="120.0" text="TIPO" />
                                    </columns>
                                </TableView>

                                <VBox spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 10; -fx-padding: 15;">
                                    <children>
                                        <Label text="⚡ Acción Rápida de Inventario:" textFill="WHITE">
                                            <font><Font name="System Bold" size="13.0" /></font>
                                        </Label>
                                        <HBox spacing="10.0">
                                            <children>
                                                <TextField fx:id="txtAjusteCant" prefWidth="80.0" promptText="Cant." style="-fx-background-color: rgba(0,0,0,0.3); -fx-text-fill: white;" />
                                                <TextField fx:id="txtMotivoAjuste" promptText="Motivo para dar de baja (Obligatorio para restar/eliminar)" style="-fx-background-color: rgba(0,0,0,0.3); -fx-text-fill: white;" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button maxWidth="Infinity" onAction="#sumarStockExistente" prefHeight="35.0" style="-fx-background-color: rgba(0, 210, 255, 0.1); -fx-border-color: #00d2ff; -fx-border-radius: 8; -fx-text-fill: #00d2ff; -fx-font-weight: bold;" text="➕ Sumar Stock" HBox.hgrow="ALWAYS" />
                                                <Button maxWidth="Infinity" onAction="#restarStock" prefHeight="35.0" style="-fx-background-color: rgba(243, 156, 18, 0.1); -fx-border-color: #f39c12; -fx-border-radius: 8; -fx-text-fill: #f39c12; -fx-font-weight: bold;" text="➖ Restar Manual" HBox.hgrow="ALWAYS" />
                                                <Button maxWidth="Infinity" onAction="#eliminarProducto" prefHeight="35.0" style="-fx-background-color: rgba(255, 76, 76, 0.1); -fx-border-color: #ff4c4c; -fx-border-radius: 8; -fx-text-fill: #ff4c4c; -fx-font-weight: bold;" text="🗑 Eliminar/Dar Baja" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox minWidth="380.0" prefWidth="380.0" spacing="12.0" style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-radius: 15;">
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                            <children>
                                <Label text="Crear Nuevo Producto" textFill="WHITE">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>

                                <Label text="¿Qué tipo de producto es?" textFill="#00ff88">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <ComboBox fx:id="cmbTipoClase" prefWidth="Infinity" promptText="Seleccione (Pizza, Bebida, Postre...)" style="-fx-base: #1a0a2a;" />

                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <ImageView fx:id="imgPreview" fitHeight="60.0" fitWidth="60.0" style="-fx-background-color: rgba(0,0,0,0.5);" />
                                        <Button mnemonicParsing="false" onAction="#seleccionarImagen" style="-fx-background-color: transparent; -fx-border-color: #b39ddb; -fx-border-radius: 5; -fx-text-fill: #b39ddb;" text="🖼 Subir Imagen..." />
                                    </children>
                                </HBox>

                                <Label text="Nombre y Precio:" textFill="#b39ddb" />
                                <HBox spacing="10.0">
                                    <children>
                                        <TextField fx:id="txtNombre" promptText="Ej: Pizza Hawaiana" style="-fx-background-color: rgba(0,0,0,0.3); -fx-text-fill: white;" HBox.hgrow="ALWAYS" />
                                        <TextField fx:id="txtPrecio" prefWidth="80.0" promptText="Bs. 0.00" style="-fx-background-color: rgba(0,0,0,0.3); -fx-text-fill: white;" />
                                    </children>
                                </HBox>

                                <HBox spacing="10.0">
                                    <children>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Categoría del Menú:" textFill="#b39ddb" />
                                                <ComboBox fx:id="cmbCategoria" editable="true" prefWidth="Infinity" promptText="Ej: Pizzas Clásicas" style="-fx-base: #1a0a2a; -fx-control-inner-background: rgba(0,0,0,0.3);" />
                                            </children>
                                        </VBox>
                                        <VBox>
                                            <children>
                                                <Label text="Stock Inicial:" textFill="#b39ddb" />
                                                <TextField fx:id="txtStock" prefWidth="80.0" promptText="0" style="-fx-background-color: rgba(0,0,0,0.3); -fx-text-fill: white;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox fx:id="panelAtributosDinamicos" spacing="8.0" style="-fx-background-color: rgba(0,0,0,0.2); -fx-padding: 10; -fx-background-radius: 5;" />

                                <Label text="Receta de Cocina (Opcional)" textFill="WHITE">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>

                                <HBox spacing="10.0">
                                    <children>
                                        <ComboBox fx:id="cmbInsumos" prefWidth="200.0" promptText="Seleccione Insumo..." style="-fx-base: #1a0a2a;" HBox.hgrow="ALWAYS" />
                                        <TextField fx:id="txtCantidadReceta" prefWidth="70.0" promptText="Cant." style="-fx-background-color: rgba(0,0,0,0.3); -fx-text-fill: white;" />
                                        <Button mnemonicParsing="false" onAction="#agregarIngredienteVisual" style="-fx-background-color: rgba(243, 156, 18, 0.2); -fx-border-color: #f39c12; -fx-border-radius: 5; -fx-text-fill: #f39c12;" text="➕" />
                                    </children>
                                </HBox>

                                <TableView fx:id="tablaRecetaFila" prefHeight="120.0" style="-fx-base: #1a0a2a; -fx-control-inner-background: #1a0a2a;">
                                    <columns>
                                        <TableColumn fx:id="colRecetaInsumo" prefWidth="180.0" text="INGREDIENTE" />
                                        <TableColumn fx:id="colRecetaCant" prefWidth="100.0" text="CANTIDAD" />
                                    </columns>
                                </TableView>

                                <AnchorPane VBox.vgrow="ALWAYS" />

                                <Button mnemonicParsing="false" onAction="#guardarNuevoProducto" prefHeight="45.0" prefWidth="Infinity" style="-fx-background-color: linear-gradient(to right, #00ff88, #00cc6a); -fx-text-fill: #120524; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;" text="💾 GUARDAR PRODUCTO FINAL" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
