<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #120524;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Attizos.Frontend.CocinaController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label text="👨‍🍳 PANTALLA DE COCINA " textFill="WHITE">
                            <font><Font name="System Bold" size="26.0" /></font>
                        </Label>
                        <AnchorPane HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnCerrar" focusTraversable="false" mnemonicParsing="false" onAction="#cerrarVentana" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: transparent; -fx-border-color: #ff4c4c; -fx-border-radius: 10; -fx-border-width: 2; -fx-text-fill: #ff4c4c; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="❌ CERRAR" />
                    </children>
                </HBox>

                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>

                        <VBox prefWidth="400.0" spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="📋 Cola de Espera:" textFill="#b39ddb">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>

                                <TableView fx:id="tablaPedidos" style="-fx-font-size: 16px; -fx-base: #1a0a2a; -fx-control-inner-background: #1a0a2a; -fx-background-color: #1a0a2a; -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 10;" VBox.vgrow="ALWAYS">
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                    <columns>
                                        <TableColumn fx:id="colIdPedido" prefWidth="100.0" text="N° PEDIDO" />
                                        <TableColumn fx:id="colEstado" prefWidth="150.0" text="ESTADO" />
                                    </columns>
                                </TableView>

                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#cancelarPedidoSeleccionado" prefHeight="45.0" style="-fx-background-color: rgba(255, 76, 76, 0.1); -fx-border-color: #ff4c4c; -fx-border-radius: 12; -fx-border-width: 2; -fx-text-fill: #ff4c4c; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="🛑 Cancelar Pedido Seleccionado" />
                            </children>
                        </VBox>

                        <VBox prefWidth="450.0" spacing="10.0" style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-radius: 15;" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                            <children>
                                <Label fx:id="lblPedidoActual" text="Seleccione un pedido..." textFill="WHITE">
                                    <font><Font name="System Bold" size="22.0" /></font>
                                </Label>

                                <Label text="PREPARAR LO SIGUIENTE:" textFill="#b39ddb">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>

                                <ListView fx:id="listaDetallesCocina" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-base: #1a0a2a; -fx-control-inner-background: rgba(15, 5, 30, 0.6); -fx-background-color: transparent; -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 10;" VBox.vgrow="ALWAYS" />

                                <Button fx:id="btnConfirmar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#atenderSiguiente" prefHeight="60.0" style="-fx-background-color: linear-gradient(to right, #00ff88, #00cc6a); -fx-text-fill: #120524; -fx-font-weight: bold; -fx-font-size: 18px; -fx-background-radius: 12; -fx-cursor: hand;" text="✅ ¡PLATO LISTO! (Atender Siguiente)" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
