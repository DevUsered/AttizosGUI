<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="768.0" prefWidth="1024.0" style="-fx-background-color: #13111b;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Attizos.Frontend.CocinaController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: #1c1a24; -fx-border-color: #2b2738; -fx-border-width: 0 0 2 0; -fx-padding: 15;">
            <children>
                <Label text="MONITOR DE COCINA" textFill="#ff9800">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER_RIGHT">
                    <children>
                        <Label fx:id="lblNombreCocinero" text="Cocinero" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <Label text="Estación Activa" textFill="#4caf50">
                            <font>
                                <Font size="10.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <Button mnemonicParsing="false" onAction="#cerrarSesion" style="-fx-background-color: #ff4c4c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" text="Cerrar Sesión" />
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #13111b; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <FlowPane fx:id="panelPedidos" hgap="20.0" vgap="20.0" style="-fx-padding: 30;">
                    <children>
                        <Label text="Esperando nuevos pedidos..." textFill="#7a7a7a">
                            <font>
                                <Font size="18.0" />
                            </font>
                        </Label>
                    </children>
                </FlowPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>