<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Attizos.Frontend.SalesController">
    <children>
        <HBox spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox prefWidth="400.0" spacing="15.0" style="-fx-background-color: #1c1a24; -fx-background-radius: 15; -fx-border-color: #2b2738; -fx-border-radius: 15; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Menú de Pizzería" textFill="WHITE">
                            <font><Font name="System Bold" size="22.0" /></font>
                        </Label>
                        <ComboBox fx:id="comboCategoria" maxWidth="Infinity" promptText="Seleccionar categoría..." style="-fx-background-color: #2b2738; -fx-text-fill: white; -fx-background-radius: 8;" styleClass="dark-combo" />
                        <TableView fx:id="tablaProductos" styleClass="dark-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colProdNombre" prefWidth="200.0" text="PRODUCTO" />
                                <TableColumn fx:id="colProdPrecio" prefWidth="80.0" text="PRECIO" />
                                <TableColumn fx:id="colProdStock" prefWidth="70.0" text="STOCK" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#agregarAlCarrito" prefHeight="45.0" style="-fx-background-color: linear-gradient(to right, #8b5cf6, #7c3aed); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-size: 14px;" text="➡🛒 Agregar al Carrito" />
                    </children>
                </VBox>
                <VBox prefWidth="480.0" spacing="15.0" style="-fx-background-color: #1c1a24; -fx-background-radius: 15; -fx-border-color: #2b2738; -fx-border-radius: 15; -fx-padding: 20;">
                    <children>
                        <Label text="Carrito de Compras" textFill="#a855f7">
                            <font><Font name="System Bold" size="22.0" /></font>
                        </Label>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Label text="Cliente:" textFill="#7a7a7a">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <TextField fx:id="txtNombreCliente" promptText="Nombre del cliente..." style="-fx-background-color: #0f0d14; -fx-text-fill: white; -fx-prompt-text-fill: #4d4a5d; -fx-border-color: #2b2738; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>

                        <TableView fx:id="tablaCarrito" styleClass="dark-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colCarProducto" prefWidth="180.0" text="PRODUCTO" />
                                <TableColumn fx:id="colCarCant" prefWidth="60.0" text="CANT" />
                                <TableColumn fx:id="colCarSubtotal" prefWidth="90.0" text="SUBTOT" />
                            </columns>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#restarProducto" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="➖ Restar 1" />
                                <Button mnemonicParsing="false" onAction="#eliminarProducto" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="🗑 Quitar Todo" />
                            </children>
                        </HBox>
                        <VBox alignment="CENTER_RIGHT" style="-fx-background-color: #0f0d14; -fx-background-radius: 10; -fx-border-color: #2b2738; -fx-border-radius: 10; -fx-padding: 15;">
                            <children>
                                <Label text="TOTAL A PAGAR:" textFill="#7a7a7a">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <Label fx:id="lblTotal" text="Bs. 0.00" textFill="#4caf50">
                                    <font><Font name="System Bold" size="36.0" /></font>
                                </Label>
                            </children>
                        </VBox>

                        <Button mnemonicParsing="false" onAction="#procesarVenta" maxWidth="Infinity" prefHeight="55.0" style="-fx-background-color: linear-gradient(to right, #10b981, #059669); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 10; -fx-cursor: hand;" text="✅ FINALIZAR VENTA E IMPRIMIR" />

                    </children>
                </VBox>
            </children>
        </HBox>
    </children>

</AnchorPane>
